{
  "name": "nominmaxable",
  "version": "1.0.0",
  "description": "parkrun full event name length analysis by series and country",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.{ts,html,css}\" \"scripts/**/*.mjs\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,css}\" \"scripts/**/*.mjs\"",
    "typecheck": "tsc --noEmit",
    "precommit": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run build && pnpm run test:run",
    "screenshots": "node scripts/capture-social-preview.mjs",
    "prepare": "husky"
  },
  "keywords": [
    "parkrun"
  ],
  "author": "Pete Johns",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "playwright": "^1.59.1",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.8",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.33.0"
}
